rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: {userId} (matches auth.uid)
    // Fields:
    //   - uid: string (required)
    //   - name: string (required)
    //   - email: string (required)
    //   - role: string (admin, instructor, student)
    //   - instructorId: string (optional, for students)
    //   - subscription: object (optional)
    //     - status: string (active, inactive)
    //     - updatedAt: timestamp
    //
    // Collection: workouts
    // Fields: studentId, instructorId, exercises, date, studentName
    //
    // Collection: water
    // Document ID: {userId}_{date}
    // Fields: studentId, ml, date
    //
    // Collection: financials
    // Fields: instructorId, amount, type, description, date
    //
    // Collection: assessments
    // Fields: studentId, instructorId, weight, height, bodyFat, muscleMass, bodyWater, visceralFat, imc, date, measurements
    //
    // Collection: meals
    // Fields: studentId, mealDescription, analysis, calories, date
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && 
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
         request.auth.token.email == "thelo.tech2714@gmail.com"); // User email from context
    }

    function isInstructor() {
      return isAuthenticated() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'instructor';
    }

    function isStudentOf(instructorId) {
      return isAuthenticated() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.instructorId == instructorId;
    }

    function isValidDateString(dateStr) {
      return dateStr is string && dateStr.matches("^\\d{4}-\\d{2}-\\d{2}$");
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if (isOwner(userId) && (
        !request.resource.data.diff(resource.data).affectedKeys().hasAny(['subscription', 'role']) ||
        (request.resource.data.subscription.status == 'pending' && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['subscription']))
      )) || isAdmin();
    }

    match /workouts/{workoutId} {
      allow read: if isAuthenticated() && (isOwner(resource.data.studentId) || isOwner(resource.data.instructorId) || isAdmin());
      allow create: if isAuthenticated();
      allow update, delete: if isAuthenticated() && (isOwner(resource.data.instructorId) || isAdmin());
    }

    match /water/{waterId} {
      allow read: if isAuthenticated() && (isOwner(resource.data.studentId) || isAdmin());
      allow write: if isAuthenticated() && (isOwner(request.resource.data.studentId) || isAdmin());
    }

    match /financials/{finId} {
      allow read, write: if isAuthenticated() && (isOwner(resource.data.instructorId) || isOwner(request.resource.data.instructorId) || isAdmin());
    }

    match /assessments/{assId} {
      allow read: if isAuthenticated() && (isOwner(resource.data.studentId) || isOwner(resource.data.instructorId) || isAdmin());
      allow write: if isAuthenticated() && (isOwner(resource.data.instructorId) || isOwner(request.resource.data.instructorId) || isAdmin());
    }

    match /meals/{mealId} {
      allow read: if isAuthenticated() && (isOwner(resource.data.studentId) || isAdmin());
      allow write: if isAuthenticated() && (isOwner(request.resource.data.studentId) || isAdmin());
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
