rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- Helpers ---
    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function isAdmin() { 
      return isSignedIn() && (
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
        request.auth.token.email.matches('.*thelo\\.tech2714@gmail\\.com$') ||
        request.auth.token.email.matches('.*jeferson\\.executiva\\.net@gmail\\.com$')
      );
    }
    function isInstructor() {
      return isSignedIn() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'instructor';
    }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    // --- Safety Net ---
    match /{document=**} {
      allow read, write: if false;
    }

    // --- System Logs ---
    match /system_logs/{logId} {
      allow create: if isSignedIn();
      allow read: if isAdmin();
    }

    // --- Users Collection ---
    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin() || isInstructor();
      allow list: if isAdmin();
      allow create: if isSignedIn() && isOwner(userId) && 
        incoming().role == 'student' && 
        incoming().status == 'pending';
      allow update: if isAdmin() || (
        isOwner(userId) && 
        isValidUpdateAction(existing(), incoming())
      );
    }

    function isValidUpdateAction(existing, incoming) {
      let allowedKeys = ['name', 'photoURL', 'fcmTokens', 'updatedAt', 'points'];
      let isBasicUpdate = incoming.diff(existing).affectedKeys().hasOnly(['name', 'photoURL', 'fcmTokens', 'updatedAt']);
      let isPointIncrement = incoming.diff(existing).affectedKeys().hasOnly(['points', 'updatedAt']) && 
                             incoming.points >= existing.points && 
                             incoming.points <= existing.points + 1000;
      
      return isBasicUpdate || isPointIncrement;
    }

    // --- Instructors Collection ---
    match /instructors/{instructorId} {
      allow read: if isOwner(instructorId) || isAdmin();
      allow write: if isOwner(instructorId) || isAdmin();
    }

    // --- Students Collection ---
    match /students/{studentId} {
      allow read: if isSignedIn() && (
        isOwner(studentId) || 
        isAdmin() || 
        isInstructor() && existing().instructorId == request.auth.uid
      );
      
      allow update: if (
        isAdmin() || 
        isInstructor() && existing().instructorId == request.auth.uid ||
        (isOwner(studentId) && isValidUpdateAction(existing(), incoming()))
      );
      
      allow create: if isAdmin() || isInstructor();
    }

    // --- Workouts & Sessions ---
    match /workouts/{studentId} {
      allow read: if isOwner(studentId) || isAdmin() || (isInstructor() && get(/databases/$(database)/documents/students/$(studentId)).data.instructorId == request.auth.uid);
      allow write: if isAdmin() || (isInstructor() && get(/databases/$(database)/documents/students/$(studentId)).data.instructorId == request.auth.uid);
    }

    match /workout_sessions/{sessionId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && incoming().studentId == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    // --- Messaging ---
    match /messages/{messageId} {
      allow read: if isSignedIn() && (resource.data.fromId == request.auth.uid || resource.data.toId == request.auth.uid);
      allow create: if isSignedIn() && incoming().fromId == request.auth.uid;
    }

    // --- Payment Approvals ---
    match /payment_approvals/{approvalId} {
      allow read: if isAdmin() || (isSignedIn() && resource.data.instructorId == request.auth.uid);
      allow create: if isSignedIn();
      allow update: if isAdmin();
    }

    // --- Notifications ---
    match /notifications/{notificationId} {
      allow read: if isSignedIn() && resource.data.toId == request.auth.uid;
      allow write: if isAdmin() || (isSignedIn() && incoming().toId == request.auth.uid);
    }

    // --- Subscription Plans ---
    match /plans/{planId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
  }
}
