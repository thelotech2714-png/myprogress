{
  "entities": {
    "User": {
      "title": "User",
      "description": "Base user profile information.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "name": { "type": "string" },
        "role": { "type": "string", "enum": ["student", "instructor", "admin"] },
        "status": { "type": "string", "enum": ["active", "pending", "blocked"] },
        "points": { "type": "number" },
        "photoURL": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "name", "role", "status"]
    },
    "Instructor": {
      "title": "Instructor",
      "description": "Detailed information for instructor users.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "phone": { "type": "string" },
        "plan": { "type": "string" },
        "paymentStatus": { "type": "string", "enum": ["pending", "approved", "rejected"] },
        "experiencia": { "type": "string" },
        "especialidade": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "phone", "plan", "paymentStatus"]
    },
    "Student": {
      "title": "Student",
      "description": "Information linking a student to an instructor and their progress.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "instructorId": { "type": "string" },
        "accessReleased": { "type": "boolean" },
        "status": { "type": "string", "enum": ["active", "blocked", "deleted"] },
        "plan": { "type": "string" },
        "points": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "status", "points"]
    },
    "PaymentApproval": {
      "title": "Payment Approval",
      "description": "Request for admin to approve an instructor's payment/plan.",
      "type": "object",
      "properties": {
        "instructorId": { "type": "string" },
        "plan": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["instructorId", "plan", "status"]
    },
    "Notification": {
      "title": "Notification",
      "description": "System or user notifications.",
      "type": "object",
      "properties": {
        "toId": { "type": "string" },
        "title": { "type": "string" },
        "message": { "type": "string" },
        "read": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["toId", "title", "message", "read"]
    },
    "Message": {
      "title": "Message",
      "description": "Inter-user messages or support chats.",
      "type": "object",
      "properties": {
        "fromId": { "type": "string" },
        "fromName": { "type": "string" },
        "toId": { "type": "string" },
        "content": { "type": "string" },
        "type": { "type": "string", "enum": ["chat", "support"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["fromId", "toId", "content", "type"]
    },
    "ProgressPhoto": {
      "title": "Progress Photo",
      "description": "Photos uploaded by students to track changes.",
      "type": "object",
      "properties": {
        "studentId": { "type": "string" },
        "url": { "type": "string" },
        "type": { "type": "string", "enum": ["before", "after"] },
        "date": { "type": "string", "format": "date-time" }
      },
      "required": ["studentId", "url", "type"]
    },
    "Workout": {
      "title": "Workout",
      "description": "The current workout plan for a student.",
      "type": "object",
      "properties": {
        "studentId": { "type": "string" },
        "workout": { "type": "object" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["studentId", "workout"]
    },
    "WorkoutSession": {
      "title": "Workout Session",
      "description": "A completed workout session with points and results.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "studentId": { "type": "string" },
        "rewardPoints": { "type": "number" },
        "duration": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "studentId"]
    },
    "Plan": {
      "title": "Plan",
      "description": "Available subscription plans for instructors.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "price": { "type": "number" },
        "currency": { "type": "string" },
        "features": { "type": "array", "items": { "type": "string" } },
        "active": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name", "price", "active"]
    },
    "SystemLog": {
      "title": "System Log",
      "description": "Logs for debugging and auditing.",
      "type": "object",
      "properties": {
        "error": { "type": "string" },
        "operationType": { "type": "string" },
        "path": { "type": "string" },
        "userId": { "type": "string" },
        "serverTime": { "type": "string", "format": "date-time" }
      }
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles by UID."
    },
    "/instructors/{userId}": {
      "schema": "Instructor",
      "description": "Instructor details by UID."
    },
    "/students/{userId}": {
      "schema": "Student",
      "description": "Student details by UID."
    },
    "/payment_approvals/{userId}": {
      "schema": "PaymentApproval",
      "description": "Payment approval requests for instructors."
    },
    "/notifications/{notificationId}": {
      "schema": "Notification",
      "description": "Notifications collection."
    },
    "/messages/{messageId}": {
      "schema": "Message",
      "description": "Direct messages and support logs."
    },
    "/progress_photos/{photoId}": {
      "schema": "ProgressPhoto",
      "description": "Student progress photos."
    },
    "/workouts/{studentId}": {
      "schema": "Workout",
      "description": "Current workout for a student."
    },
    "/workout_sessions/{sessionId}": {
      "schema": "WorkoutSession",
      "description": "Log of completed workouts."
    },
    "/plans/{planId}": {
      "schema": "Plan",
      "description": "Plans available for subscription."
    },
    "/system_logs/{logId}": {
      "schema": "SystemLog",
      "description": "Internal error and action logs."
    }
  }
}
